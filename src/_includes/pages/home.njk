{# src/_includes/pages/home.njk #}

<!-- ── Hero ─────────────────────────────────────────────── -->
<section class="wrapper" style="padding-block: 3rem 2rem;">
  <div class="hero">
    <div class="hero-content">
      <p class="section-label">Direct from Uganda</p>
      <h1>{{ hero.heading }}</h1>
      {% if hero.subtext %}<p class="subtext">{{ hero.subtext }}</p>{% endif %}
      {% if hero.cta_label and hero.cta_href %}
        <div>
          <a href="{{ hero.cta_href }}" class="btn">{{ hero.cta_label }}</a>
        </div>
      {% endif %}
    </div>
    <div class="hero-img">
      {% if hero.video %}
        <video src="{{ hero.video }}" controls playsinline style="width:100%;height:100%;object-fit:cover;"></video>
      {% else %}
        <img src="{{ hero.image }}" alt="Zuricaf hero">
      {% endif %}
    </div>
  </div>
</section>

<!-- ── Services ──────────────────────────────────────────── -->
<section id="services" class="section-bg" style="padding-block: var(--section-gap);">
  <div class="wrapper">
    <p class="section-label">What we offer</p>
    <h2>Services &amp; Modules</h2>
    <div class="module-grid">
      {% for item in services %}
        {% if item.icon %}
          <svg data-lucide="{{ item.icon }}" width="20" height="20"></svg>
        {% else %}
          <div></div>
        {% endif %}
        <div>
          <strong>{{ item.title }}</strong>
          <span>{{ item.desc }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── How it works ───────────────────────────────────────── -->
{% if how_it_works %}
<section id="how-it-works" class="section">
  <div class="wrapper">
    <p class="section-label">The model</p>
    <h2>How It Works</h2>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Origin &amp; Export</h3>
        <p>Our Ugandan partners consolidate lots across farms in Mount Elgon, Rwenzori, Masaka and West Nile — handling aggregation and international export.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>Import &amp; Customs</h3>
        <p>Zuricaf handles German import, customs clearance, and delivery to your roastery — from 10 bags, no full container needed.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>Key Account &amp; Quality</h3>
        <p>Permanent contact in Germany: SCA cuppings, Q-grader feedback, sample service, and repeat order management.</p>
      </div>
    </div>
    <p style="margin-top:1.5rem;font-size:.85rem;color:var(--fg-light);">
      2026 in partnership with CCPAU (Uganda), Slow Food Uganda, and the Uganda Embassy Berlin.
    </p>
  </div>
</section>
{% endif %}

<!-- ── Sustainability ─────────────────────────────────────── -->
<section id="sustainability" class="section section-bg">
  <div class="wrapper">
    <p class="section-label">Our values</p>
    <div class="prose">{{ sustainability | markdown | safe }}</div>
  </div>
</section>

<!-- ── Liberica ──────────────────────────────────────────── -->
<section id="liberica" class="section">
  <div class="wrapper">
    <p class="section-label">Specialty varieties</p>
    <div class="prose">{{ liberica | markdown | safe }}</div>
  </div>
</section>

{# Additional CMS sections #}
{% if sections and sections.length %}
  {% for s in sections %}
    {% if s.type == "text" %}
      <section{% if s.id %} id="{{ s.id }}"{% endif %} class="section">
        <div class="wrapper">
          {% if s.heading %}<h2>{{ s.heading }}</h2>{% endif %}
          <div class="prose">{{ s.body | markdown | safe }}</div>
        </div>
      </section>

    {% elif s.type == "image_text" %}
      <section{% if s.id %} id="{{ s.id }}"{% endif %} class="section">
        <div class="wrapper">
          {% if s.heading %}<h2>{{ s.heading }}</h2>{% endif %}
          <div class="img-text-grid">
            <div class="img{% if s.image_right %} img-order-right{% endif %}">
              {% if s.src %}<img src="{{ s.src }}" alt="{{ s.alt }}" style="border-radius:var(--radius);">{% endif %}
            </div>
            <div class="prose">{{ s.body | markdown | safe }}</div>
          </div>
        </div>
      </section>

    {% elif s.type == "cta" %}
      <section{% if s.id %} id="{{ s.id }}"{% endif %} class="section-bg" style="padding-block:var(--section-gap);">
        <div class="wrapper cta-block">
          <h2>{{ s.heading }}</h2>
          <p>{{ s.text }}</p>
          <div class="btn-group">
            {% for b in s.buttons or [] %}
              <a class="btn" href="{{ b.href }}">{{ b.label }}</a>
            {% endfor %}
          </div>
        </div>
      </section>
    {% endif %}
  {% endfor %}
{% endif %}

<!-- ── Harvest Calendar ───────────────────────────────────── -->
<section id="calendar" class="section section-bg">
  <div class="wrapper">
    <p class="section-label">Seasonality</p>
    <h2>Uganda Harvest Calendar <span style="font-size:.8rem;font-weight:400;color:var(--fg-light);">(indicative – varies by micro-climate)</span></h2>
    <div style="overflow-x:auto;margin-top:1rem;">
      <table class="calendar">
        <thead>
          <tr><th>Region</th><th>Type</th><th>Main Crop</th><th>Fly Crop</th></tr>
        </thead>
        <tbody>
          {% for row in calendar %}
            <tr>
              <td>{{ row.region }}</td>
              <td>{{ row.type }}</td>
              <td>{{ row.main }}</td>
              <td>{{ row.fly }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ── Contact ───────────────────────────────────────────── -->
<section id="contact" class="section">
  <div class="wrapper" style="max-width:640px;">
    <p class="section-label">Get in touch</p>
    <h2 style="margin-bottom:.5rem;">Contact us</h2>
    <p style="color:var(--fg-mid);margin-bottom:2rem;">Questions about sourcing, the delegation, or the supplier registration? We'll get back to you within 24 hours.</p>

    <form name="contact" method="POST" netlify netlify-honeypot="bot-field" action="/contact-thanks/">
      <input type="hidden" name="form-name" value="contact">
      <p style="display:none;"><label>Don't fill this out: <input name="bot-field"></label></p>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem 1.5rem;margin-bottom:1rem;">
        <div>
          <label class="c-label" for="c_name">Name <span style="color:var(--accent)">*</span></label>
          <input id="c_name" name="name" type="text" required placeholder="Your name" class="c-input">
        </div>
        <div>
          <label class="c-label" for="c_email">Email <span style="color:var(--accent)">*</span></label>
          <input id="c_email" name="email" type="email" required placeholder="your@email.com" class="c-input">
        </div>
      </div>
      <div style="margin-bottom:1.5rem;">
        <label class="c-label" for="c_message">Message <span style="color:var(--accent)">*</span></label>
        <textarea id="c_message" name="message" required rows="5" placeholder="How can we help?" class="c-input" style="resize:vertical;"></textarea>
      </div>
      <button type="submit" class="btn">Send message</button>
    </form>
  </div>
</section>

<style>
  .c-label { display:block;font-size:.88rem;font-weight:600;margin-bottom:.35rem;color:var(--fg); }
  .c-input  { width:100%;padding:.55rem .75rem;border:1px solid var(--border);border-radius:var(--radius);font-family:inherit;font-size:.95rem;color:var(--fg);background:#fff;transition:border-color .15s; }
  .c-input:focus { outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(200,89,58,.12); }
</style>

<!-- ── CTA ───────────────────────────────────────────────── -->
<section id="cta" class="section section-bg">
  <div class="wrapper cta-block">
    <h2>{{ cta.heading }}</h2>
    <p>{{ cta.text }}</p>
    <div class="btn-group">
      {% for b in cta.buttons %}
        <a href="{{ b.href }}" class="btn{% if loop.index > 1 %} btn-outline{% endif %}">{{ b.label }}</a>
      {% endfor %}
    </div>
  </div>
</section>
