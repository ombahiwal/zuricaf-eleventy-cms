{# src/_includes/pages/lot-info.njk #}

{# ── Lot fields macro ─────────────────────────────────── #}
{% macro lotFields(n, isFirst) %}
<div>
  <details class="accordion" {% if isFirst %}open{% endif %}>
    <summary class="accordion-summary">
      <span data-en="Lot Details &amp; Pricing" data-lg="Ebikwata ku Lot &amp; Omuwendo">Lot Details &amp; Pricing</span>
      <svg data-lucide="chevron-down" width="16" height="16" class="accordion-icon"></svg>
    </summary>
    <div class="accordion-body">

      <div class="field-grid-2">
        <div>
          <label class="field-label" for="variety_{{ n }}">
            <span data-en="Variety / species" data-lg="Ekika ky'emmwanyi">Variety / species</span>{% if isFirst %} <span class="req">*</span>{% endif %}
            <span class="field-hint" data-en="SL14, SL28, Nyasaland, Robusta, Excelsa, other" data-lg="SL14, SL28, Nyasaland, Robusta, Excelsa, ebirala">SL14, SL28, Nyasaland, Robusta, Excelsa, other</span>
          </label>
          <input id="variety_{{ n }}" name="lot_{{ n }}_variety" type="text"
            {% if isFirst %}required{% endif %}
            data-ph-en="List all varieties" data-ph-lg="Wandiika ebika byonna"
            placeholder="List all varieties" class="field-input">
        </div>
        <div>
          <label class="field-label" for="processing_{{ n }}">
            <span data-en="Processing method" data-lg="Engeri y'okukola">Processing method</span> <span class="req">*</span>
          </label>
          <select id="processing_{{ n }}" name="lot_{{ n }}_processing" required class="field-select">
            <option value="" disabled selected>&mdash; select &mdash;</option>
            <option>Washed / Fully Washed</option>
            <option>Natural / Dry Process</option>
            <option>Honey / Pulped Natural</option>
            <option>Semi-washed</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label class="field-label" for="quantity_{{ n }}">
            <span data-en="Quantity (60 kg bags)" data-lg="Obungi (amasaho ag'obuundu 60 kg)">Quantity (60 kg bags)</span> <span class="req">*</span>
          </label>
          <input id="quantity_{{ n }}" name="lot_{{ n }}_quantity" type="number" min="1" required
            data-ph-en="e.g. 20" data-ph-lg="Eky'okulabirako: 20"
            placeholder="e.g. 20" class="field-input">
        </div>
        <div>
          <label class="field-label" for="altitude_{{ n }}">
            <span data-en="Altitude (masl)" data-lg="Buwanvu (masl)">Altitude (masl)</span>
          </label>
          <input id="altitude_{{ n }}" name="lot_{{ n }}_altitude" type="number" min="0" max="3000"
            data-ph-en="e.g. 1600" data-ph-lg="Eky'okulabirako: 1600"
            placeholder="e.g. 1600" class="field-input">
        </div>
        <div>
          <label class="field-label" for="status_{{ n }}">
            <span data-en="Current status" data-lg="Embeera kati">Current status</span>
          </label>
          <select id="status_{{ n }}" name="lot_{{ n }}_status" class="field-select">
            <option value="" disabled selected>&mdash; select &mdash;</option>
            <option>Ready to ship</option>
            <option>Currently drying</option>
            <option>Currently processing</option>
            <option>Still on the tree</option>
            <option>Other</option>
          </select>
        </div>
      </div>

      <!-- Price block -->
      <div style="margin-top:1rem;padding:1rem;background:var(--bg-warm);border:1px solid var(--border);border-radius:var(--radius);">
        <p class="field-label" style="margin-bottom:.1rem;">
          <span data-en="Price per kg (USD)" data-lg="Omuwendo ku kg (USD)">Price per kg (USD)</span> <span class="req">*</span>
        </p>
        <p style="font-size:.78rem;color:var(--fg-light);margin-bottom:.75rem;">
          <span data-en="Your price at collection point or farm gate" data-lg="Omuwendo gwo mu kifo ky'okukunganya oba ku luggya lw'oluggya">Your price at collection point or farm gate</span>
        </p>
        <div style="display:flex;gap:.5rem;align-items:flex-end;margin-bottom:.75rem;">
          <div style="flex:1;">
            <label class="field-label" style="font-weight:400;font-size:.8rem;" for="price_{{ n }}">
              <span data-en="Amount" data-lg="Omuwendo">Amount</span>
            </label>
            <input id="price_{{ n }}" name="lot_{{ n }}_price" type="number" min="0" step="0.01" required
              data-ph-en="e.g. 4.50" data-ph-lg="Eky'okulabirako: 4.50"
              placeholder="e.g. 4.50" class="field-input">
          </div>
          <div style="flex:0 0 90px;">
            <label class="field-label" style="font-weight:400;font-size:.8rem;" for="currency_{{ n }}">
              <span data-en="Currency" data-lg="Ensimbi">Currency</span>
            </label>
            <select id="currency_{{ n }}" name="lot_{{ n }}_currency" required class="field-select">
              <option value="USD" selected>USD</option>
              <option value="UGX">UGX</option>
            </select>
          </div>
        </div>
        <label class="check-label" style="font-size:.85rem;margin-bottom:.75rem;">
          <input type="checkbox" name="lot_{{ n }}_excl_milling" value="Excludes milling/processing costs">
          <span data-en="This price excludes milling / processing costs" data-lg="Omuwendo guno tegutereka ebisente by'okusengeja / okukola">This price excludes milling / processing costs</span>
        </label>
        <div>
          <label class="field-label" style="font-weight:400;font-size:.8rem;" for="min_order_{{ n }}">
            <span data-en="Minimum order (bags)" data-lg="Obungi obuto obw'okugulawo">Minimum order (bags)</span>
          </label>
          <input id="min_order_{{ n }}" name="lot_{{ n }}_min_order" type="number" min="1"
            data-ph-en="e.g. 5" data-ph-lg="Eky'okulabirako: 5"
            placeholder="e.g. 5" class="field-input">
        </div>
      </div>

    </div>
  </details>

  <details class="accordion">
    <summary class="accordion-summary">
      <span data-en="Quality &amp; Certifications" data-lg="Obuwombeefu &amp; Ebiwandiiko">Quality &amp; Certifications</span>
      <svg data-lucide="chevron-down" width="16" height="16" class="accordion-icon"></svg>
    </summary>
    <div class="accordion-body">

      <div>
        <label class="field-label" for="cupping_{{ n }}">
          <span data-en="Cupping score (if available)" data-lg="Akalulu ak'okugezesa emmwanyi">Cupping score (if available)</span>
          <span class="field-hint" data-en="SCA score — leave blank if not scored yet" data-lg="Akalulu ka SCA — siga nga temukigezesaako">SCA score — leave blank if not scored yet</span>
        </label>
        <input id="cupping_{{ n }}" name="lot_{{ n }}_cupping_score" type="text"
          data-ph-en="e.g. 84.5" data-ph-lg="Eky'okulabirako: 84.5"
          placeholder="e.g. 84.5" class="field-input" style="max-width:180px;">
      </div>

      <div style="margin-top:1rem;">
        <span class="field-label" data-en="Certifications" data-lg="Ebiwandiiko by'okukakasa">Certifications</span>
        <div style="display:flex;flex-direction:column;gap:.4rem;margin-top:.5rem;">
          <label class="check-label"><input type="checkbox" name="lot_{{ n }}_cert_slowfood" value="Slow Food Coffee Presidio"> Slow Food Coffee Presidio</label>
          <label class="check-label"><input type="checkbox" name="lot_{{ n }}_cert_organic" value="Organic (certified)"> Organic (certified)</label>
          <label class="check-label"><input type="checkbox" name="lot_{{ n }}_cert_rainforest" value="Rainforest Alliance / UTZ"> Rainforest Alliance / UTZ</label>
          <label class="check-label"><input type="checkbox" name="lot_{{ n }}_cert_fairtrade" value="Fair Trade"> Fair Trade</label>
          <label class="check-label"><input type="checkbox" name="lot_{{ n }}_cert_none" value="None"> None currently</label>
        </div>
      </div>

      <div style="margin-top:1rem;">
        <label class="field-label" for="material_{{ n }}">
          <span data-en="Additional material" data-lg="Ebintu ebirala">Additional material</span>
          <span class="field-hint" data-en="Link to cupping notes, farm profile PDF, or photos" data-lg="Omuddo gw'ebiwandiiko, PDF, oba ebifaananyi">Link to cupping notes, farm profile PDF, or photos</span>
        </label>
        <input id="material_{{ n }}" name="lot_{{ n }}_material" type="text"
          data-ph-en="https://… (Google Drive, Dropbox, etc.)" data-ph-lg="https://… (Google Drive, Dropbox, n'ebirala)"
          placeholder="https://… (Google Drive, Dropbox, etc.)" class="field-input">
      </div>

      <div style="margin-top:1rem;">
        <label class="field-label" for="notes_{{ n }}">
          <span data-en="Notes" data-lg="Ebirowoozo">Notes</span>
        </label>
        <textarea id="notes_{{ n }}" name="lot_{{ n }}_notes" rows="3"
          data-ph-en="Harvest timing, special characteristics, packaging preferences, etc."
          data-ph-lg="Ebbanga ery'okutema, eby'enjawulo, engeri y'okupaaka, n'ebirala"
          placeholder="Harvest timing, special characteristics, packaging preferences, etc."
          class="field-input"></textarea>
      </div>

    </div>
  </details>
</div>
{% endmacro %}

{# ── Page ─────────────────────────────────────────────── #}
<main>
<div class="wrapper" style="padding-top:2.5rem;padding-bottom:4rem;">

  <!-- Language toggle -->
  <div style="display:flex;align-items:center;justify-content:flex-end;gap:.5rem;margin-bottom:1.5rem;">
    <span style="font-size:.8rem;color:var(--fg-light);">Language:</span>
    <div class="lang-toggle" role="group" aria-label="Language">
      <button type="button" class="lang-btn lang-btn--active" id="btn-en" onclick="setLang('en')">EN</button>
      <button type="button" class="lang-btn" id="btn-lg" onclick="setLang('lg')">LG</button>
    </div>
  </div>

  <h1 style="margin-bottom:.25rem;">Coffee lot information</h1>
  <p style="color:var(--fg-light);font-size:.95rem;margin:0 0 .5rem;">
    German roaster delegation &middot; Uganda, May 2026
  </p>
  <p style="color:var(--fg-mid);font-size:.9rem;margin:0 0 2.5rem;max-width:540px;">
    One form per <strong>farm, cooperative, or group</strong>. Fields marked <span class="req">*</span> are required — everything else is optional but helps us evaluate your lot. You can add up to 5 lots below.
  </p>

  <form
    name="coffee-lot-info"
    method="POST"
    netlify
    netlify-honeypot="bot-field"
    action="/lot-info/thanks/"
    style="max-width:680px;"
    id="lot-form"
  >
    <input type="hidden" name="form-name" value="coffee-lot-info">
    <p style="display:none;"><label>Don't fill this out: <input name="bot-field"></label></p>

    <!-- ── FARM & CONTACT ─────────────────────────────── -->
    <details class="accordion" open>
      <summary class="accordion-summary accordion-summary--top">
        <span data-en="Farm &amp; Contact" data-lg="Oluggya &amp; Omuntu ow'okukwatako">Farm &amp; Contact</span>
        <svg data-lucide="chevron-down" width="16" height="16" class="accordion-icon"></svg>
      </summary>
      <div class="accordion-body">

        <div style="margin-bottom:1.25rem;">
          <label class="field-label" for="farmer_org">
            <span data-en="Member organisation (if any)" data-lg="Ekibiina (singa wali mu kibiina)">Member organisation (if any)</span>
            <span class="field-hint" data-en="e.g. CCPAU, Slow Food, UCFA" data-lg="Eky'okulabirako: CCPAU, Slow Food, UCFA">e.g. CCPAU, Slow Food, UCFA</span>
          </label>
          <input id="farmer_org" name="farmer_org" type="text"
            data-ph-en="e.g. CCPAU, Slow Food, UCFA"
            data-ph-lg="Eky'okulabirako: CCPAU, Slow Food, UCFA"
            placeholder="e.g. CCPAU, Slow Food, UCFA"
            class="field-input">
        </div>

        <div class="field-grid-2">
          <div>
            <label class="field-label" for="farm_name">
              <span data-en="Farm / Cooperative / Group name" data-lg="Erinnya ly'oluggya / ekibiina">Farm / Cooperative / Group name</span> <span class="req">*</span>
            </label>
            <input id="farm_name" name="farm_name" type="text" required
              data-ph-en="e.g. Kyarusozi Women's Coffee Group" data-ph-lg="Eky'okulabirako: Ekibiina ky'abakazi ka Kyarusozi"
              placeholder="e.g. Kyarusozi Women's Coffee Group" class="field-input">
          </div>
          <div>
            <label class="field-label" for="region">
              <span data-en="Region / district" data-lg="Essaza / Akaawunyisa">Region / district</span> <span class="req">*</span>
            </label>
            <input id="region" name="region" type="text" required
              data-ph-en="e.g. Fort Portal, Kapchorwa" data-ph-lg="Eky'okulabirako: Fort Portal, Kapchorwa"
              placeholder="e.g. Fort Portal, Kapchorwa" class="field-input">
          </div>
          <div>
            <label class="field-label" for="contact_name">
              <span data-en="Contact name" data-lg="Erinnya ly'omuntu ow'okukwatako">Contact name</span> <span class="req">*</span>
            </label>
            <input id="contact_name" name="contact_name" type="text" required
              data-ph-en="Full name" data-ph-lg="Erinnya lyona"
              placeholder="Full name" class="field-input">
          </div>
          <div>
            <label class="field-label" for="phone">
              <span data-en="WhatsApp / phone" data-lg="WhatsApp / Essimu">WhatsApp / phone</span> <span class="req">*</span>
            </label>
            <input id="phone" name="phone" type="tel" required
              data-ph-en="+256 …" data-ph-lg="+256 …"
              placeholder="+256 …" class="field-input">
          </div>
        </div>

        <div style="margin-top:1rem;">
          <label class="field-label" for="email">
            <span data-en="Email" data-lg="Email">Email</span> <span class="req">*</span>
          </label>
          <input id="email" name="email" type="email" required
            data-ph-en="your@email.com" data-ph-lg="your@email.com"
            placeholder="your@email.com" class="field-input">
        </div>
        <div style="margin-top:1rem;">
          <label class="field-label" for="social_link">
            <span data-en="Farm website or social media" data-lg="Webusaiti oba social media">Farm website or social media</span>
            <span class="field-hint" data-en="Instagram, Facebook, or any page with farm information" data-lg="Instagram, Facebook, oba olupapula olwonna olw'amawulire g'oluggya">Instagram, Facebook, or any page with farm information</span>
          </label>
          <input id="social_link" name="social_link" type="text"
            data-ph-en="www.instagram.com/yourfarm or https://…" data-ph-lg="www.instagram.com/oluggya-lwo oba https://…"
            placeholder="www.instagram.com/yourfarm or https://…" class="field-input">
        </div>

        <div style="margin-top:1rem;">
          <label class="field-label" for="programme_stop">
            <span data-en="Which programme stop / date are you part of?" data-lg="Olimu ggwe ki mu mutendera gw'olugendo?">Which programme stop / date are you part of?</span>
            <span class="field-hint" data-en="e.g. Sample only · In-person visit, 5 May" data-lg="Eky'okulabirako: Sampuli yokka · Okujja mu maaso, 5 May">e.g. Sample only · In-person visit, 5 May</span>
          </label>
          <input id="programme_stop" name="programme_stop" type="text"
            data-ph-en="e.g. In-person visit, 5 May" data-ph-lg="Eky'okulabirako: Okujja mu maaso, 5 May"
            placeholder="e.g. In-person visit, 5 May" class="field-input">
        </div>

      </div>
    </details>

    <!-- ── LOTS ───────────────────────────────────────── -->
    <div id="lots-container">

      <div class="lot-block" id="lot-1">
        <div class="lot-header">
          <span class="lot-badge">Lot 1</span>
        </div>
        {{ lotFields("1", true) }}
      </div>

      <div class="lot-block lot-extra" id="lot-2" style="display:none;">
        <div class="lot-header">
          <span class="lot-badge">Lot 2</span>
          <button type="button" class="lot-remove" onclick="removeLot(2)">Remove</button>
        </div>
        {{ lotFields("2", false) }}
      </div>

      <div class="lot-block lot-extra" id="lot-3" style="display:none;">
        <div class="lot-header">
          <span class="lot-badge">Lot 3</span>
          <button type="button" class="lot-remove" onclick="removeLot(3)">Remove</button>
        </div>
        {{ lotFields("3", false) }}
      </div>

      <div class="lot-block lot-extra" id="lot-4" style="display:none;">
        <div class="lot-header">
          <span class="lot-badge">Lot 4</span>
          <button type="button" class="lot-remove" onclick="removeLot(4)">Remove</button>
        </div>
        {{ lotFields("4", false) }}
      </div>

      <div class="lot-block lot-extra" id="lot-5" style="display:none;">
        <div class="lot-header">
          <span class="lot-badge">Lot 5</span>
          <button type="button" class="lot-remove" onclick="removeLot(5)">Remove</button>
        </div>
        {{ lotFields("5", false) }}
      </div>

    </div>

    <button type="button" id="add-lot-btn" onclick="addLot()"
      style="display:flex;align-items:center;gap:.5rem;background:none;border:1.5px dashed var(--border);border-radius:var(--radius);padding:.65rem 1.2rem;font-family:inherit;font-size:.88rem;font-weight:600;color:var(--fg-mid);cursor:pointer;width:100%;justify-content:center;margin-bottom:2.5rem;transition:border-color .15s,color .15s;">
      <span data-en="+ &nbsp;Add another lot" data-lg="+ &nbsp;Gattako oluvannyuma olulala">+ &nbsp;Add another lot</span>
    </button>

    <button type="submit" class="btn" id="submit-btn">
      <span data-en="Submit lot information &nbsp;↗" data-lg="Weereza amawulire g'olot &nbsp;↗">Submit lot information &nbsp;↗</span>
    </button>

    <p style="font-size:.8rem;color:var(--fg-light);margin-top:1.25rem;max-width:500px;">
      Your pricing data is confidential and will not be shared with other farmers. It is used solely to calculate indicative landed prices for the German roasters.
    </p>

  </form>
</div>
</main>

<style>
  /* Language toggle */
  .lang-toggle { display:flex;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden; }
  .lang-btn { padding:.3rem .75rem;font-family:inherit;font-size:.8rem;font-weight:600;background:var(--bg);border:none;cursor:pointer;color:var(--fg-mid);transition:background .15s,color .15s; }
  .lang-btn--active { background:var(--accent);color:#fff; }

  /* Accordion */
  .accordion { border:1px solid var(--border);border-radius:var(--radius);margin-bottom:.75rem;background:var(--bg);overflow:hidden; }
  .accordion-summary { display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.1rem;cursor:pointer;font-weight:600;font-size:.9rem;list-style:none;user-select:none;background:var(--bg-warm);transition:background .15s; }
  .accordion-summary::-webkit-details-marker { display:none; }
  .accordion-summary:hover { background:#f0ede8; }
  .accordion-summary--top { font-size:.95rem;padding:1rem 1.1rem; }
  details[open] .accordion-icon { transform:rotate(180deg); }
  .accordion-icon { transition:transform .2s;stroke:var(--fg-mid);flex-shrink:0; }
  .accordion-body { padding:1.25rem 1.1rem;border-top:1px solid var(--border); }

  /* Fields */
  .field-grid-2 { display:grid;grid-template-columns:1fr 1fr;gap:1rem 1.5rem; }
  .field-label  { display:block;font-size:.88rem;font-weight:600;margin-bottom:.35rem;color:var(--fg); }
  .field-hint   { display:block;font-weight:400;font-size:.8rem;color:var(--fg-light);margin-top:.1rem; }
  .req          { color:var(--accent); }
  .field-input, .field-select { width:100%;padding:.55rem .75rem;border:1px solid var(--border);border-radius:var(--radius);font-family:inherit;font-size:.95rem;color:var(--fg);background:#fff;transition:border-color .15s; }
  .field-input:focus, .field-select:focus { outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(200,89,58,.12); }
  textarea.field-input { min-height:90px;resize:vertical; }
  .check-label  { display:flex;align-items:center;gap:.5rem;font-size:.92rem;cursor:pointer; }
  .check-label input[type="checkbox"] { width:15px;height:15px;accent-color:var(--accent);flex-shrink:0; }

  /* Lot blocks */
  .lot-block { margin-bottom:1.25rem; }
  .lot-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem; }
  .lot-badge  { font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--accent); }
  .lot-remove { background:none;border:none;font-family:inherit;font-size:.8rem;color:var(--fg-light);cursor:pointer;padding:.2rem .4rem;border-radius:4px;transition:color .15s; }
  .lot-remove:hover { color:var(--accent); }
  #add-lot-btn:hover { border-color:var(--accent);color:var(--accent); }

  @media (max-width:560px) { .field-grid-2 { grid-template-columns:1fr; } }
</style>

<script>
  /* ── Language toggle ── */
  var currentLang = 'en';

  function setLang(lang) {
    currentLang = lang;
    // Toggle button styles
    document.getElementById('btn-en').classList.toggle('lang-btn--active', lang === 'en');
    document.getElementById('btn-lg').classList.toggle('lang-btn--active', lang === 'lg');
    // Swap all data-en / data-lg text nodes
    document.querySelectorAll('[data-en][data-lg]').forEach(function(el) {
      el.innerHTML = el.getAttribute('data-' + lang);
    });
    // Swap placeholders
    document.querySelectorAll('[data-ph-en][data-ph-lg]').forEach(function(el) {
      el.placeholder = el.getAttribute('data-ph-' + lang);
    });
  }

  /* ── Lots ── */
  var visibleLots = 1;
  var MAX_LOTS = 5;

  function addLot() {
    if (visibleLots >= MAX_LOTS) return;
    visibleLots++;
    var block = document.getElementById('lot-' + visibleLots);
    if (block) {
      block.style.display = '';
      block.querySelectorAll('input,select,textarea').forEach(function(el) { el.disabled = false; });
      var firstDetails = block.querySelector('details');
      if (firstDetails) firstDetails.open = true;
      // Apply current language to new lot
      if (currentLang !== 'en') setLang(currentLang);
    }
    if (visibleLots >= MAX_LOTS) document.getElementById('add-lot-btn').style.display = 'none';
    if (window.lucide) lucide.createIcons();
  }

  function removeLot(n) {
    var block = document.getElementById('lot-' + n);
    if (block) {
      block.style.display = 'none';
      block.querySelectorAll('input,select,textarea').forEach(function(el) {
        el.disabled = true;
        if (el.type !== 'checkbox') el.value = '';
        if (el.type === 'checkbox') el.checked = false;
      });
    }
    visibleLots = Math.max(1, visibleLots - 1);
    document.getElementById('add-lot-btn').style.display = '';
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.lot-extra').forEach(function(block) {
      block.querySelectorAll('input,select,textarea').forEach(function(el) { el.disabled = true; });
    });
    if (window.lucide) lucide.createIcons();
  });
</script>
